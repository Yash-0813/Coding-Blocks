import java.util.Scanner;
import java.util.Stack;
public class Main {

public static void main(String[] args) {
		Scanner sc= new Scanner(System.in);
		Stack<Integer> stack = new Stack<>();
		int t = sc.nextInt();
		for (int i = 0; i <t; i++) {
			int val1 = sc.nextInt();
			if(val1==2) {
				int val2 = sc.nextInt();
				stack.push(val2);
			}
			else {
				if(stack.isEmpty()) {
					System.out.println("No Code");
				}
				else {
					System.out.println(stack.pop());
				}
			}
			
		}

	}

}
